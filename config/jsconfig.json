/**
 * jsconfig.json
 * 
 * Configuração de paths do JavaScript/TypeScript
 * - Define alias '@/*' que aponta para raiz do projeto
 * - Permite importações limpas: import X from '@/lib/supabase'
 * - Melhora autocompletar e resolução de módulos no editor
 * - Funciona em Next.js 16+ automaticamente
 */

{
  "compilerOptions": {
    "paths": {
      "@/*": ["./*"]
    }
  }
}